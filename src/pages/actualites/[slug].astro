---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { CalendarIcon, ArrowLeftIcon } from '@heroicons/react/24/outline';

const { slug } = Astro.params;
const actualites = await getCollection('actualites');
const article = actualites.find(a => a.id === slug);

if (!article) {
  return Astro.redirect('/actualites');
}

const { data } = article;
const { Content } = await render(article);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));
};
---

<Layout title={data.titre} description={`Actualité du SEHC — ${data.titre}`} image={data.cover}>
  <article class="bg-white">
    <!-- Back Button -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pt-8">
      <a href="/actualites" class="inline-flex items-center gap-2 text-yellow-600 hover:text-yellow-800 font-medium transition-colors">
        <ArrowLeftIcon className="h-5 w-5" />
        Retour aux actualités
      </a>
    </div>

    <!-- Cover Image -->
    {data.cover && (
      <div class="mx-auto max-w-2xl px-6 lg:px-8 mt-8">
        <div class="rounded-3xl overflow-hidden shadow-2xl">
          <img
            src={data.cover}
            alt={data.titre}
            class="w-full h-auto block"
          />
        </div>
      </div>
    )}

    <!-- Article Header -->
    <div class="mx-auto max-w-3xl px-6 lg:px-8 mt-12">
      <p class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <CalendarIcon className="h-4 w-4 text-yellow-600" />
        {formatDate(data.date)}
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
        {data.titre}
      </h1>
    </div>

    <!-- Article Content -->
    <div class="mx-auto max-w-3xl px-6 lg:px-8 mt-10 pb-24 article-content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .article-content :global(h1) { font-size: 2rem; }
  .article-content :global(h2) { font-size: 1.5rem; }
  .article-content :global(h3) { font-size: 1.25rem; }

  .article-content :global(p) {
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .article-content :global(a) {
    color: #ca8a04;
    text-decoration: underline;
  }
  .article-content :global(a:hover) {
    color: #92400e;
  }

  .article-content :global(img) {
    border-radius: 1rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    max-width: 100%;
    margin: 1.5rem auto;
    display: block;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.75;
  }
  .article-content :global(ul) { list-style-type: disc; }
  .article-content :global(ol) { list-style-type: decimal; }
  .article-content :global(li) { margin-bottom: 0.25rem; }

  .article-content :global(blockquote) {
    border-left: 4px solid #ca8a04;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #6b7280;
    font-style: italic;
  }

  .article-content :global(iframe) {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }

  .article-content :global(hr) {
    border-color: #e5e7eb;
    margin: 2rem 0;
  }
</style>
