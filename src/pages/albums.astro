---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Récupérer tous les albums
const albums = await getCollection('albums');

// Trier par ordre puis par date (plus récent en premier)
const albumsSorted = albums.sort((a: any, b: any) => {
  if (a.data.ordre !== b.data.ordre) {
    return (a.data.ordre || 0) - (b.data.ordre || 0);
  }
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Formater la date
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(new Date(date));
};
---

<Layout title="Albums Photo">
  <div class="bg-white">
    <!-- Section Albums -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Header -->
        <div class="mx-auto max-w-2xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
            Albums Photo
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Découvrez les moments forts du club en photos
          </p>
        </div>

        <!-- Albums Grid -->
        {albumsSorted.length > 0 ? (
          <ul class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            {albumsSorted.map((album: any) => (
              <li>
                <a href={album.data.lien_externe} target="_blank" rel="noopener noreferrer" class="group block">
                  {album.data.cover_image ? (
                    <div class="relative overflow-hidden rounded-2xl shadow-lg">
                      <img
                        class="aspect-[16/10] w-full object-cover group-hover:scale-105 transition-transform duration-300"
                        src={album.data.cover_image}
                        alt={album.data.nom}
                      />
                      <!-- Overlay with external link icon -->
                      <div class="absolute inset-0 group-hover:bg-opacity-30 transition-opacity duration-300 flex items-center justify-center">
                        <svg class="h-12 w-12 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </div>
                    </div>
                  ) : (
                    <div class="aspect-[16/10] w-full rounded-2xl bg-gray-200 flex items-center justify-center shadow-lg">
                      <svg class="h-20 w-20 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                  <div class="mt-6">
                    <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900 group-hover:text-yellow-600 transition-colors">
                      {album.data.nom}
                    </h3>
                    <p class="text-base leading-7 text-gray-600 flex items-center gap-2 mt-2">
                      <svg class="h-4 w-4 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      {formatDate(album.data.date)}
                    </p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div class="mt-20 text-center text-gray-600">
            <p class="mb-4">Aucun album pour le moment.</p>
            <p>Ajoutez des albums via l'<a href="/keystatic" class="text-yellow-600 hover:text-yellow-800 underline">interface Keystatic</a></p>
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>
