---
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { getCollection } from 'astro:content';

const reader = createReader(process.cwd(), keystaticConfig);
const pageClub = await reader.singletons.page_club.read();

// Récupérer les partenaires pour la section logos
const partenaires = await getCollection('partenaires');
const partenairesSorted = partenaires.sort((a: any, b: any) => (a.data.ordre || 0) - (b.data.ordre || 0));

// Récupérer toutes les personnes pour résoudre les références
const personnes = await getCollection('personnes');

// Heroicons map pour les commissions
const heroiconsMap: Record<string, string> = {
  whistle: 'M9 9a2 2 0 114 0 2 2 0 01-4 0zm8-2.5a.5.5 0 00-1 0V9a1 1 0 11-2 0V6.5a.5.5 0 00-1 0V9a2 2 0 104 0V6.5z',
  store: 'M3 3h18v4H3V3zm1 5h16v9H4V8zm3 2v5h2v-5H7zm4 0v5h2v-5h-2z',
  communication: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  discipline: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  beer: 'M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7',
};
---

<Layout title={pageClub?.entete_titre || 'Le Club'}>
  <div class="bg-white">
    <!-- Tabs de navigation -->
    <div class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <nav class="flex space-x-8 overflow-x-auto" aria-label="Sections">
          <a href="#histoire" class="whitespace-nowrap py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm">
            Histoire
          </a>
          <a href="#conseil" class="whitespace-nowrap py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm">
            Conseil d'Administration
          </a>
          <a href="#commissions" class="whitespace-nowrap py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm">
            Commissions
          </a>
          <a href="#partenaires" class="whitespace-nowrap py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm">
            Partenaires
          </a>
          <a href="#boutique" class="whitespace-nowrap py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm">
            Boutique
          </a>
        </nav>
      </div>
    </div>

    <!-- Section À Propos / Histoire -->
    <section id="histoire" class="py-24 sm:py-32 bg-yellow-50 scroll-mt-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-8">
            {pageClub?.apropos_titre}
          </h2>
          <p class="text-lg text-gray-700 whitespace-pre-line">
            {pageClub?.apropos_contenu}
          </p>
        </div>
      </div>
    </section>

    <!-- Section Conseil d'Administration -->
    <section id="conseil" class="py-24 sm:py-32 bg-white scroll-mt-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-2">
            {pageClub?.conseil_titre}
          </h2>
        </div>

        <!-- LE BUREAU -->
        <div class="mb-20">
          <div class="relative mb-12">
            <div class="absolute inset-0 flex items-center" aria-hidden="true">
              <div class="w-full border-t-4 border-yellow-600"></div>
            </div>
            <div class="relative flex justify-center">
              <span class="bg-white px-8 text-2xl font-bold text-gray-900">LE BUREAU</span>
            </div>
          </div>

          {pageClub?.bureau_membres && pageClub.bureau_membres.length > 0 ? (
            <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {pageClub.bureau_membres.map((membre: any) => {
                const personne = personnes.find((p: any) => p.id === membre.personne);
                if (!personne) return null;
                return (
                  <div class="flex flex-col items-center text-center">
                    <div class="relative mb-6">
                      <div class="absolute inset-0 rounded-full border-8 border-yellow-400 -rotate-12"></div>
                      <div class="relative">
                        {personne.data.photo ? (
                          <img
                            src={personne.data.photo}
                            alt={personne.data.nom}
                            class="h-40 w-40 rounded-full object-cover border-8 border-yellow-400"
                          />
                        ) : (
                          <div class="h-40 w-40 rounded-full bg-gray-200 border-8 border-white flex items-center justify-center">
                            <svg class="h-20 w-20 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                          </div>
                        )}
                      </div>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900">{personne.data.nom}</h3>
                    {membre.fonction && (
                      <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">{membre.fonction}</p>
                    )}
                    {membre.email && (
                      <p class="text-sm font-medium text-yellow-400 tracking-wide">{membre.email}</p>
                    )}
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="text-center text-gray-600 py-8">
              <p>Aucun membre du bureau ajouté. Ajoutez-les via <a href="/keystatic" class="text-yellow-600 hover:text-yellow-800 underline">Keystatic</a></p>
            </div>
          )}
        </div>

        <!-- LES MEMBRES -->
        <div>
          <div class="relative mb-12">
            <div class="absolute inset-0 flex items-center" aria-hidden="true">
              <div class="w-full border-t-4 border-yellow-600"></div>
            </div>
            <div class="relative flex justify-center">
              <span class="bg-white px-8 text-2xl font-bold text-gray-900">LES MEMBRES</span>
            </div>
          </div>

          {pageClub?.conseil_membres && pageClub.conseil_membres.length > 0 ? (
            <div class="grid grid-cols-2 gap-12 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
              {pageClub.conseil_membres.map((membreSlug: string) => {
                const personne = personnes.find((p: any) => p.id === membreSlug);
                if (!personne) return null;
                return (
                  <div class="flex flex-col items-center text-center">
                    <div class="relative mb-4">
                      <div class="absolute inset-0 rounded-full border-8 border-yellow-400 rotate-12"></div>
                      <div class="relative">
                        {personne.data.photo ? (
                          <img
                            src={personne.data.photo}
                            alt={personne.data.nom}
                            class="h-32 w-32 rounded-full object-cover border-8 border-yellow-400"
                          />
                        ) : (
                          <div class="h-32 w-32 rounded-full bg-gray-200 border-8 border-white flex items-center justify-center">
                            <svg class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                          </div>
                        )}
                      </div>
                    </div>
                    <h3 class="text-base font-bold text-gray-900">{personne.data.nom}</h3>
                    <p class="text-xs font-medium text-gray-600 uppercase">MEMBRE</p>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="text-center text-gray-600 py-8">
              <p>Aucun membre du conseil ajouté. Ajoutez-les via <a href="/keystatic" class="text-yellow-600 hover:text-yellow-800 underline">Keystatic</a></p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Section Commissions -->
    {pageClub?.commissions && pageClub.commissions.length > 0 && (
      <section id="commissions" class="py-24 sm:py-32 bg-gray-50 scroll-mt-16">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="text-center mb-16">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
              LES COMMISSIONS
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {pageClub.commissions.map((commission: any) => (
              <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                <!-- Contenu de la card -->
                <div class="p-6">
                  <!-- Icône + Titre -->
                  <div class="flex items-center gap-3 mb-4">
                    <div class="flex-shrink-0">
                      <svg class="h-8 w-8 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d={heroiconsMap[commission.icone] || heroiconsMap.whistle} />
                      </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900">
                      {commission.nom}
                    </h3>
                  </div>

                  <!-- Description -->
                  <div class="text-gray-600 text-sm space-y-1 mb-4">
                    {commission.description.split('\n').map((ligne: string) => (
                      ligne.trim() && <p>• {ligne.trim()}</p>
                    ))}
                  </div>
                </div>

                <!-- Bandeau email en bas -->
                <div class="bg-yellow-400 px-6 py-3 mt-2 mx-2 mb-2 rounded-md">
                  <a href={`mailto:${commission.email}`} class="text-sm font-medium text-gray-900 hover:underline flex items-center gap-2">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    {commission.email}
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Section Liste de Logos de Partenaires -->
    <section id="partenaires" class="py-24 sm:py-32 bg-white scroll-mt-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <h2 class="text-center text-3xl font-bold tracking-tight text-gray-900 mb-12">
          Nos Partenaires
        </h2>
        <p class="text-center text-lg text-gray-600 mb-12">
          Présentation des partenaires du club avec leurs logos et une brève description de leur contribution.
        </p>

        {partenairesSorted.length > 0 ? (
          <div class="grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-4">
            {partenairesSorted.map((partenaire: any) => (
              <div class="flex flex-col items-center">
                {partenaire.data.url ? (
                  <a
                    href={partenaire.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full"
                  >
                    <img
                      src={partenaire.data.logo}
                      alt={partenaire.data.nom}
                      class="h-24 w-full object-contain grayscale hover:grayscale-0 transition-all"
                    />
                  </a>
                ) : (
                  <img
                    src={partenaire.data.logo}
                    alt={partenaire.data.nom}
                    class="h-24 w-full object-contain"
                  />
                )}
                <p class="mt-4 text-sm font-medium text-gray-900">{partenaire.data.nom}</p>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center text-gray-600">
            <p>Aucun partenaire ajouté. Ajoutez des partenaires via l'<a href="/keystatic" class="text-yellow-600 hover:text-yellow-800 underline">interface Keystatic</a></p>
          </div>
        )}
      </div>
    </section>

    <!-- Section Boutique/Ecommerce -->
    <section id="boutique" class="py-24 sm:py-32 bg-yellow-50 scroll-mt-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            {pageClub?.boutique_titre}
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            {pageClub?.boutique_description}
          </p>
          <div class="mt-10">
            <a
              href={pageClub?.boutique_lien || '#'}
              class="rounded-3xl bg-black px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-yellow-600 hover:text-black transition-colors"
            >
              Visiter la boutique
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Script pour smooth scroll -->
  <script>
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') as string);
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  </script>
</Layout>
