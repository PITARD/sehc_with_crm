---
import { getCollection } from 'astro:content';
import { CalendarIcon, ArrowRightIcon } from '@heroicons/react/24/outline';
import { NewspaperIcon } from '@heroicons/react/24/outline';

const actualites = await getCollection('actualites');
const latest = actualites
  .sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

if (latest.length === 0) return;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(date));
---

<div class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl lg:text-center mb-16">
      <h2 class="text-base/7 font-semibold text-yellow-600">Le club en direct</h2>
      <p class="mt-2 text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-balance">
        Dernières actualités
      </p>
    </div>

    <!-- Articles -->
    <ul class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((article: any, index: number) => (
        <li class={index === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}>
          <a href={`/actualites/${article.id}`} class="group flex flex-col h-full bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
            {article.data.cover ? (
              <div class="overflow-hidden">
                <img
                  class="aspect-[16/9] w-full object-cover group-hover:scale-105 transition-transform duration-300"
                  src={article.data.cover}
                  alt={article.data.titre}
                />
              </div>
            ) : (
              <div class="aspect-[16/9] w-full bg-yellow-50 flex items-center justify-center">
                <NewspaperIcon className="h-16 w-16 text-yellow-200" />
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              <p class="flex items-center gap-1.5 text-xs text-gray-400 mb-3">
                <CalendarIcon className="h-3.5 w-3.5 text-yellow-500" />
                {formatDate(article.data.date)}
              </p>
              <h3 class="text-base font-semibold text-gray-900 group-hover:text-yellow-600 transition-colors leading-snug flex-1">
                {article.data.titre}
              </h3>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <!-- Link to all articles -->
    <div class="mt-12 text-center">
      <a
        href="/actualites"
        class="inline-flex items-center gap-2 rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-gray-900 hover:bg-yellow-300 transition-colors"
      >
        Toutes les actualités
        <ArrowRightIcon className="h-4 w-4" />
      </a>
    </div>
  </div>
</div>
