---
import { getCollection } from "astro:content";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../../keystatic.config';

// Lire les stats et les trier par ordre
const stats = await getCollection("stats");
const statsSorted = stats.sort((a: any, b: any) => (a.data.ordre || 0) - (b.data.ordre || 0));

// Lire les titres depuis home_content
const reader = createReader(process.cwd(), keystaticConfig);
const homeContent = await reader.singletons.home_content.read();

const sectionTitre = homeContent?.section_stats_titre || 'Nos Performances';
const sectionDescription = homeContent?.section_stats_description || 'Découvrez les statistiques du club !';
---

<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-none">
      <div class="text-center">
        <h2
          class="text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
          {sectionTitre}
        </h2>
        <p class="mt-4 text-lg/8 text-gray-600">
          {sectionDescription}
        </p>
      </div>
      <dl
        class="mt-16 grid grid-cols-1 gap-0.5 overflow-hidden rounded-2xl text-center sm:grid-cols-2 lg:grid-cols-4">
        {
          statsSorted.map((stat: any) => (
            <div class="flex flex-col bg-yellow-400/5 p-8">
              <dt class="text-sm/6 font-semibold text-gray-600">
                {stat.data.name}
              </dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900">
                {stat.data.value}
                {stat.data.sigle}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</div>
