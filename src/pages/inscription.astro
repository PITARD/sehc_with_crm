---
import Layout from "../layouts/Layout.astro";
import { getEntry } from "astro:content";

const pageInscription = (await getEntry('configs', 'page-inscription'))?.data as any;

// Map des icônes pour les documents
const iconesMap: Record<string, string> = {
  document:
    "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  medical:
    "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z M7 13h10M7 17h10M9 3v4",
  photo:
    "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z",
  "id-card":
    "M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2",
};
---

<Layout title="Nous rejoindre" description="Inscrivez-vous au Sud Estuaire Handball Club. Toutes les catégories, de 3 ans aux adultes. Documents nécessaires et formulaire en ligne.">
  <div class="bg-white">
    <!-- Section 1: Hero avec explication, image et CTA -->
    <section
      class="relative overflow-hidden bg-gradient-to-b from-yellow-50 to-white py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div
          class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-center">
          <!-- Texte -->
          <div class="lg:pr-8">
            <div class="lg:max-w-lg">
              <h1
                class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
                {pageInscription?.hero_titre || "Rejoignez le SEHC"}
              </h1>
              <p
                class="mt-6 text-lg leading-8 text-gray-600 whitespace-pre-line">
                {
                  pageInscription?.hero_description ||
                    "Que vous soyez débutant ou confirmé, enfant ou adulte, rejoignez notre club et découvrez la passion du handball!"
                }
              </p>

              <!-- CTA Button -->
              <div class="mt-10 flex items-center gap-x-6">
                <a
                  href={pageInscription?.bouton_inscription_url || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-3xl bg-yellow-600 px-8 py-4 text-lg font-semibold text-white shadow-lg hover:bg-yellow-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-yellow-600 transition-all hover:scale-105">
                  {
                    pageInscription?.bouton_inscription_texte ||
                      "S'inscrire maintenant"
                  }
                </a>
              </div>
            </div>
          </div>

          <!-- Image -->
          <div class="relative">
            {
              pageInscription?.hero_image ? (
                <img
                  src={pageInscription.hero_image}
                  alt="Rejoignez le club"
                  class="rounded-3xl shadow-2xl ring-1 ring-gray-400/10 w-full object-cover aspect-[4/3]"
                />
              ) : (
                <div class="rounded-3xl bg-gray-200 shadow-2xl aspect-[4/3] flex items-center justify-center">
                  <svg
                    class="h-24 w-24 text-gray-400"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                    />
                  </svg>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Documents nécessaires -->
    <section class="py-24 sm:py-32 bg-gray-50">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2
            class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            {pageInscription?.section_docs_titre || "Documents nécessaires"}
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Préparez ces documents pour faciliter votre inscription
          </p>
        </div>

        {
          pageInscription?.documents && pageInscription.documents.length > 0 ? (
            <div class="mx-auto mt-16 max-w-5xl">
              <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
                {pageInscription.documents.map((doc: any) => (
                  <div class="relative flex flex-col gap-6 rounded-2xl bg-white p-8 shadow-lg ring-1 ring-gray-200 hover:ring-yellow-400 transition-all">
                    <div class="flex items-center gap-4">
                      <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-yellow-100">
                        <svg
                          class="h-6 w-6 text-yellow-600"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2">
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d={iconesMap[doc.icone] || iconesMap.document}
                          />
                        </svg>
                      </div>
                      <h3 class="text-lg font-semibold text-gray-900">
                        {doc.nom}
                      </h3>
                    </div>
                    <p class="text-sm leading-6 text-gray-600 whitespace-pre-line">
                      {doc.description}
                    </p>
                    {doc.fichier && (
                      <a
                        href={doc.fichier}
                        download
                        class="inline-flex items-center gap-2 text-sm font-medium text-yellow-700 hover:text-yellow-900 underline">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                        Télécharger
                      </a>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <div class="mt-16 text-center text-gray-600">
              <p>
                Configurez les documents via{" "}
                <a
                  href="/keystatic"
                  class="text-yellow-600 hover:text-yellow-800 underline">
                  Keystatic
                </a>
              </p>
            </div>
          )
        }
      </div>
    </section>

    <!-- Section 3: Formulaire HelloAsso (iframe) -->
    {
      pageInscription?.helloasso_url && (
        <section class="py-24 sm:py-32 bg-white">
          <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center mb-12">
              <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
                {pageInscription?.section_formulaire_titre ||
                  "Formulaire d'inscription"}
              </h2>
              <p class="mt-4 text-lg text-gray-600">
                Complétez le formulaire ci-dessous pour finaliser votre
                inscription
              </p>
            </div>

            <div class="mx-auto max-w-5xl">
              <div
                class="relative overflow-hidden rounded-3xl shadow-2xl ring-1 ring-gray-200 bg-white"
                style="min-height: 800px;">
                <iframe
                  id="helloasso-iframe"
                  src={pageInscription.helloasso_url}
                  class="w-full"
                  style="height: 800px; border: none;"
                  title="Formulaire d'inscription"
                />
              </div>
            </div>
          </div>
        </section>
      )
    }
  </div>
</Layout>
