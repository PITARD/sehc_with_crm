---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
// Récupérer toutes les équipes et saisons
const equipes = await getCollection('equipes');
const saisons = await getCollection('saisons');

// Récupérer les personnes et la config pour les arbitres
const personnes = await getCollection('personnes');

const pageClub = (await getEntry('configs', 'page-club'))?.data as any;
const arbitres = pageClub?.arbitres || [];

// Trier les saisons (plus récente en premier) et identifier la courante
const saisonsSorted = [...saisons].sort((a, b) => b.data.nom.localeCompare(a.data.nom));
const currentSaison = saisons.find(s => s.data.current);
const currentSaisonId = currentSaison?.id ?? saisonsSorted[0]?.id;

// Grouper les équipes par saison, triées par ordre
const equipesBySaison: Record<string, typeof equipes> = {};
for (const equipe of equipes) {
  const key = equipe.data.saison ?? '__aucune__';
  if (!equipesBySaison[key]) equipesBySaison[key] = [];
  equipesBySaison[key].push(equipe);
}
for (const key of Object.keys(equipesBySaison)) {
  equipesBySaison[key].sort((a, b) => (a.data.ordre ?? 0) - (b.data.ordre ?? 0));
}
---

<Layout title="Nos Équipes" description="Découvrez toutes les équipes du Sud Estuaire Handball Club, des Baby Hand aux Seniors.">
  <div class="bg-white">
    <!-- Section 1: Équipes -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Header -->
        <div class="mx-auto max-w-2xl text-center">
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
            Nos Équipes
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Découvrez toutes les équipes du club, des jeunes poussin aux seniors
          </p>
        </div>

        <!-- Season switcher -->
        {saisonsSorted.length > 1 && (
          <div class="mt-12 flex justify-center gap-3 flex-wrap" id="season-switcher">
            {saisonsSorted.map(saison => (
              <button
                data-saison={saison.id}
                class={`season-btn px-5 py-2 rounded-full font-semibold text-sm transition-colors border-2 ${saison.id === currentSaisonId ? 'bg-yellow-400 border-yellow-400 text-black' : 'bg-white border-gray-300 text-gray-600 hover:border-yellow-400 hover:text-yellow-700'}`}
              >
                {saison.data.nom}
              </button>
            ))}
          </div>
        )}

        <!-- Teams grids per season -->
        {saisonsSorted.map(saison => {
          const equipesForSaison = equipesBySaison[saison.id] ?? [];
          return (
            <div
              data-saison-panel={saison.id}
              class={saison.id === currentSaisonId ? '' : 'hidden'}
            >
              {equipesForSaison.length > 0 ? (
                <ul class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
                  {equipesForSaison.map((equipe: any) => (
                    <li>
                      <a href={`/equipes/${equipe.id}`} class="group block">
                        {equipe.data.photo_equipe ? (
                          <img
                            class="aspect-[16/10] w-full rounded-2xl object-cover group-hover:opacity-90 transition-opacity shadow-lg"
                            src={equipe.data.photo_equipe}
                            alt={equipe.data.nom}
                          />
                        ) : (
                          <div class="aspect-[16/10] w-full rounded-2xl bg-gray-200 flex items-center justify-center shadow-lg">
                            <svg class="h-20 w-20 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                          </div>
                        )}
                        <h3 class="mt-6 text-lg font-semibold leading-8 tracking-tight text-gray-900 group-hover:text-yellow-600">
                          {equipe.data.nom}
                        </h3>
                        <p class="text-base leading-7 text-yellow-600 font-medium capitalize">
                          {equipe.data.niveau}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <div class="mt-20 text-center text-gray-600">
                  <p>Aucune équipe pour cette saison.</p>
                </div>
              )}
            </div>
          );
        })}

        {equipes.length === 0 && (
          <div class="mt-20 text-center text-gray-600">
            <p class="mb-4">Aucune équipe pour le moment.</p>
            <p>Ajoutez des équipes via l'<a href="/keystatic" class="text-yellow-600 hover:text-yellow-800 underline">interface Keystatic</a></p>
          </div>
        )}
      </div>
    </section>

    <script>
      const buttons = document.querySelectorAll<HTMLButtonElement>('.season-btn');
      const panels = document.querySelectorAll<HTMLElement>('[data-saison-panel]');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.saison;

          buttons.forEach(b => {
            b.classList.remove('bg-yellow-400', 'border-yellow-400', 'text-black');
            b.classList.add('bg-white', 'border-gray-300', 'text-gray-600');
          });
          btn.classList.add('bg-yellow-400', 'border-yellow-400', 'text-black');
          btn.classList.remove('bg-white', 'border-gray-300', 'text-gray-600');

          panels.forEach(panel => {
            panel.classList.toggle('hidden', panel.dataset.saisonPanel !== target);
          });
        });
      });
    </script>

    <!-- Section 2: Arbitres -->
    {arbitres.length > 0 && (
      <section class="py-24 sm:py-32 bg-gray-50">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <!-- Header -->
          <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
              {pageClub?.arbitres_titre || 'Nos Arbitres'}
            </h2>
            <p class="mt-6 text-lg leading-8 text-gray-600">
              Les arbitres officiels du club
            </p>
          </div>

          <!-- Arbitres Grid -->
          <ul class="mx-auto mt-20 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-16 sm:grid-cols-3 md:grid-cols-4 lg:mx-0 lg:max-w-none lg:grid-cols-5">
            {arbitres.map((arbitre: any) => {
              const personne = personnes.find((p: any) => p.id === arbitre.personne);
              if (!personne) return null;
              return (
                <li>
                  <div class="text-center">
                    {personne.data.photo ? (
                      <img
                        class="mx-auto h-32 w-32 rounded-full object-cover ring-4 ring-yellow-400"
                        src={personne.data.photo}
                        alt={personne.data.nom}
                      />
                    ) : (
                      <div class="mx-auto h-32 w-32 rounded-full bg-gray-200 flex items-center justify-center ring-4 ring-yellow-400">
                        <svg class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                      </div>
                    )}
                    <h3 class="mt-6 text-base font-semibold leading-7 tracking-tight text-gray-900">
                      {personne.data.nom}
                    </h3>
                    {arbitre.grade && (
                      <p class="text-sm leading-6 text-gray-600">
                        {arbitre.grade}
                      </p>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )}
  </div>
</Layout>
