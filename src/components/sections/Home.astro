---
import { getEntry } from "astro:content";
import logoNoir from "../../assets/logo_texteNoir.png";

const homeContent = (await getEntry('configs', 'home'))?.data as any;

// Images de la galerie (avec fallback sur Supabase)
const galerieImages =
  homeContent?.hero_galerie && homeContent.hero_galerie.length > 0
    ? homeContent.hero_galerie
    : [
        "https://mdhzltncrguobwkttodh.supabase.co/storage/v1/object/public/sehc/home/2.JPG",
        "https://mdhzltncrguobwkttodh.supabase.co/storage/v1/object/public/sehc/home/3.JPG",
        "https://mdhzltncrguobwkttodh.supabase.co/storage/v1/object/public/sehc/home/1.JPG",
        "https://mdhzltncrguobwkttodh.supabase.co/storage/v1/object/public/sehc/home/4.jpg",
        "https://mdhzltncrguobwkttodh.supabase.co/storage/v1/object/public/sehc/home/5.JPG",
      ];

const heroTitre =
  homeContent?.hero_titre || "Bienvenue au Club de Handball Sud Estuaire";
const heroSousTitre =
  homeContent?.hero_sous_titre ||
  "Rejoignez-nous pour partager notre passion du handball et vivre des moments inoubliables en communauté.";
const heroCtaTexte = homeContent?.hero_cta_texte || "Infos Sportives";
const heroCtaLien = homeContent?.hero_cta_lien || "/infos-sportive";
const heroCtaSecondaireTexte =
  homeContent?.hero_cta_secondaire_texte || "Nous rejoindre";
const heroCtaSecondaireLien =
  homeContent?.hero_cta_secondaire_lien || "/inscription";
---

<div class="bg-yellow-400">
  <main>
    <div class="relative isolate">
      <svg
        class="absolute inset-x-0 top-0 -z-10 h-[64rem] w-full stroke-gray-200 [mask-image:radial-gradient(32rem_32rem_at_center,white,transparent)]"
        aria-hidden="true">
        <defs>
          <pattern
            id="1f932ae7-37de-4c0a-a8b0-a6e3b4d44b84"
            width="200"
            height="200"
            x="50%"
            y="-1"
            patternUnits="userSpaceOnUse">
            <path d="M.5 200V.5H200" fill="none"></path>
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-gray-50">
          <path
            d="M-200 0h201v201h-201Z M600 0h201v201h-201Z M-400 600h201v201h-201Z M200 800h201v201h-201Z"
            stroke-width="0"></path>
        </svg>
        <rect
          width="100%"
          height="100%"
          stroke-width="0"
          fill="url(#1f932ae7-37de-4c0a-a8b0-a6e3b4d44b84)"></rect>
      </svg>
      <div
        class="absolute left-1/2 right-0 top-0 -z-10 -ml-24 transform-gpu overflow-hidden blur-3xl lg:ml-24 xl:ml-48"
        aria-hidden="true">
        <div
          class="aspect-[801/1036] w-[50.0625rem] bg-gradient-to-tr from-[#ff80b5] to-[#9089fc] opacity-30"
          style="clip-path: polygon(
            63.1% 29.5%,
            100% 17.1%,
            76.6% 3%,
            48.4% 0%,
            44.6% 4.7%,
            54.5% 25.3%,
            59.8% 49%,
            55.2% 57.8%,
            44.4% 57.2%,
            27.8% 47.9%,
            35.1% 81.5%,
            0% 97.7%,
            39.2% 100%,
            35.2% 81.4%,
            97.2% 52.8%,
            63.1% 29.5%
          );">
        </div>
      </div>
      <div class="overflow-hidden">
        <div
          class="mx-auto max-w-7xl px-6 pb-32 pt-36 sm:pt-60 lg:px-8 lg:pt-16">
          <div
            class="mx-auto max-w-2xl gap-x-14 lg:mx-0 lg:flex lg:max-w-none lg:items-center">
            <div class="relative w-full lg:max-w-xl lg:shrink-0 xl:max-w-2xl">
              <div class="flex justify-center -mt-20">
                <img
                  class="h-60 w-auto"
                  src={logoNoir.src}
                  alt="Sud Estuaire Handball Club"
                />
              </div>

              <h1
                class="text-pretty text-5xl font-semibold tracking-tight text-gray-900 sm:text-7xl">
                {heroTitre}
              </h1>
              <p
                class="mt-8 text-pretty text-lg font-medium text-gray-800 sm:max-w-md sm:text-xl/8 lg:max-w-none">
                {heroSousTitre}
              </p>
              <div class="mt-10 flex items-center gap-x-6">
                <a
                  href={heroCtaLien}
                  class="rounded-3xl bg-black px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-yellow-100 hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                  {heroCtaTexte}
                </a>
                <a
                  href={heroCtaSecondaireLien}
                  class="text-sm/6 font-semibold text-gray-900">
                  {heroCtaSecondaireTexte}
                  <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>

            <div
              class="mt-14 flex justify-end gap-8 sm:-mt-44 sm:justify-start sm:pl-20 lg:mt-0 lg:pl-0">
              <!-- Colonne 1 -->
              <div
                class="ml-auto w-44 flex-none space-y-8 pt-32 sm:ml-0 sm:pt-80 lg:order-last lg:pt-36 xl:order-none xl:pt-80">
                {
                  galerieImages[0] && (
                    <div class="relative">
                      <img
                        src={galerieImages[0]}
                        alt=""
                        class="aspect-[2/3] w-full rounded-xl bg-gray-900/5 object-cover shadow-lg"
                      />
                      <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-gray-900/10" />
                    </div>
                  )
                }
              </div>

              <!-- Colonne 2 -->
              <div
                class="mr-auto w-44 flex-none space-y-8 sm:mr-0 sm:pt-52 lg:pt-36">
                {
                  galerieImages[1] && (
                    <div class="relative">
                      <img
                        src={galerieImages[1]}
                        alt=""
                        class="aspect-[2/3] w-full rounded-xl bg-gray-900/5 object-cover shadow-lg"
                      />
                      <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-gray-900/10" />
                    </div>
                  )
                }
                {
                  galerieImages[2] && (
                    <div class="relative">
                      <img
                        src={galerieImages[2]}
                        alt=""
                        class="aspect-[2/3] w-full rounded-xl bg-gray-900/5 object-cover shadow-lg"
                      />
                      <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-gray-900/10" />
                    </div>
                  )
                }
              </div>

              <!-- Colonne 3 -->
              <div class="w-44 flex-none space-y-8 pt-32 sm:pt-0">
                {
                  galerieImages[3] && (
                    <div class="relative">
                      <img
                        src={galerieImages[3]}
                        alt=""
                        class="aspect-[2/3] w-full rounded-xl bg-gray-900/5 object-cover shadow-lg"
                      />
                      <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-gray-900/10" />
                    </div>
                  )
                }
                {
                  galerieImages[4] && (
                    <div class="relative">
                      <img
                        src={galerieImages[4]}
                        alt=""
                        class="aspect-[2/3] w-full rounded-xl bg-gray-900/5 object-cover shadow-lg"
                      />
                      <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-gray-900/10" />
                    </div>
                  )
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
